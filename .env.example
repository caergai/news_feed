# SearXNG (your instance)
SEARXNG_URL=https://your-searxng-instance/searxng

# LLM (Provider 1 - main text model)
LLM_BASE_URL=https://your-llm-endpoint/v1
LLM_API_KEY=not-needed
LLM_MODEL=minimax/minimax-m2.7

# VLM (for image/meme analysis)
VLM_MODEL=gemma-4-26b-a4b-it

# LLM params
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192

# Schedule (Eastern Time)
SCHEDULE_TIMEZONE=America/New_York
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=0

# News params
NEWS_MAX_STORIES=30
NEWS_STORIES_PER_CATEGORY=3
NEWS_DEDUP_DAYS=7
NEWS_SUMMARIZE_CONCURRENCY=3

# Paths
NEWS_OUTPUT_DIR=/path/to/your/reports
NEWS_DATA_DIR=/path/to/your/data
